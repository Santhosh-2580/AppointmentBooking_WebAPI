@using ClinicManagement.DTO.Patient
@model PatientDto

<h3>Profile</h3>

<table class="table table-hover table-bordered">

    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Mobile</th>
            <th>Email</th>
            <th>Date Of Birth</th>
            <th>Gender</th>
            <th>Age</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td>@Model.PatientName</td>
            <td>@Model.MobileNumber</td>
            <td>@Model.Email</td>
            <td>@Model.DateOfBirth</td>
            <td>@Model.Gender</td>
            <td>@Model.Age</td>
        </tr>
    </tbody>

</table>