@using ClinicManagement.DTO.Patient
@model PatientDto

<h3>Profile</h3>

@if (Model != null)
{
    <table class="table table-hover table-bordered">

        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Mobile</th>
                <th>Email</th>
                <th>Date Of Birth</th>
                <th>Gender</th>
                <th>Age</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                <td>@Model.PatientName</td>
                <td>@Model.MobileNumber</td>
                <td>@Model.Email</td>
                <td>@Model.DateOfBirth.ToString("dd-MM-yyyy")</td>
                <td>@Model.Gender</td>
                <td>@Model.Age</td>
            </tr>
        </tbody>

    </table>
}
else
{
    <div class="alert alert-warning">
        ⚠ Profile details not found. Please create your profile.
    </div>

    <a asp-controller="Patient" asp-action="CreatePatientProfile" class="btn btn-primary">
        Create Profile
    </a>
}