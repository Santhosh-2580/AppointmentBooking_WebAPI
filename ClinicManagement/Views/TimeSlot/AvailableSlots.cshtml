@using ClinicManagement.DTO.TimeSlot
@model List<TimeSlotsDto>

<h3>Available Slots</h3>

<table class="table table-hover table-bordered">

    <thead class="table-dark">

        <tr>
            
            <th>Doctor Name</th>
            <th>Specialty</th>
            <th>Date</th>
            <th>Time</th>
            <th>Available</th>
            <th>Action</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var slot in Model)
        {

            <tr>

                <td>@slot.DoctorName</td>
                <td>@slot.Specialty</td>
                <td>@slot.SlotDate</td>
                <td>@slot.StartTime - @slot.EndTime</td>
                <td>@(slot.AvailableCount)</td>

                <td>
                    @if (slot.AvailableCount == 0)
                    {
                        <button class="btn btn-secondary btn-sm" disabled>
                            Full
                        </button>
                    }
                    else if (slot.IsBookedByUser)
                    {
                        <button class="btn btn-success btn-sm" disabled title="You already booked this slot">
                            Booked
                        </button>
                    }
                    else
                    {
                        <form asp-controller="Appointment" asp-action="BookAppointment" method="post" style="display:inline;">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="TimeSlotId" value="@slot.Id" />

                            <button type="submit"
                                    class="btn btn-primary btn-sm"
                                    onclick="return confirm('Are you sure you want to book this slot?');">
                                Book
                            </button>
                        </form>
                    }
                </td>

            </tr>

        }

    </tbody>

</table>