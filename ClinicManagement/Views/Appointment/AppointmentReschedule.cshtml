@using ClinicManagement.DTO.Appointment
@model RescheduleAppointmentDto

@{
    var oldSlotId = (int)ViewBag.OldSlotId;
}

<div class="container mt-4">

    <h3 class="mb-4">Reschedule Appointment</h3>

    <!-- Current Appointment Info -->
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="fw-bold">Current Appointment</h5>

            <p><strong>Doctor:</strong> @ViewBag.DoctorName</p>
            <p><strong>Specialty:</strong> @ViewBag.Specialty</p>
            <p>
                <strong>Slot:</strong>
                @ViewBag.OldSlotDate.ToString("dd-MM-yyyy")
                (@ViewBag.OldStartTime - @ViewBag.OldEndTime)
            </p>
        </div>
    </div>

    <!-- Available Slots Table -->
    <h5 class="mb-3">Select New Slot</h5>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Doctor Name</th>
                <th>Specialty</th>
                <th>Date</th>
                <th>Time</th>
                <th>Available</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>

          
            @foreach (var slot in ViewBag.AvailableSlots)
            {
                <tr>
                    <td>@slot.DoctorName</td>
                    <td>@slot.Specialty</td>
                    <td>@slot.SlotDate.ToString("dd-MM-yyyy")</td>
                    <td>@slot.StartTime - @slot.EndTime</td>
                    <td>@slot.AvailableCount</td>

                    <td>
                        <form asp-controller="Appointment" asp-action="RescheduleAppointment" method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="AppointmentId" value="@Model.AppointmentId" />
                            <input type="hidden" name="NewTimeSlotId" value="@slot.Id" />

                            @if(slot.Id == oldSlotId)
                            {
                                <button class="btn btn-secondary btn-sm" disabled title="This is current slot">
                                    Current Slot
                                </button>
                            }

                            else if (slot.AvailableCount == 0)
                            {
                                <button class="btn btn-secondary btn-sm" disabled>Full</button>
                            }
                            else
                            {
                                <button type="submit"
                                        class="btn btn-warning btn-sm"
                                        onclick="return confirm('Are you sure you want to reschedule to this slot?');">
                                    Reschedule
                                </button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>

    </table>

    <!-- Back Button -->
    <a asp-controller="Dashboard" asp-action="PatientDashboard" class="btn btn-secondary mt-3">Back</a>

</div>